# Facebook Automation - Root Environment File
# Copy this to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
MONGODB_URI=mongodb://localhost:27017/facebook-automation

# ===========================================
# OpenAI API Configuration
# ===========================================
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# For OpenRouter (alternative):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=<your-openrouter-api-key>
# OPENAI_MODEL=google/gemma-2-9b-it:free

# ===========================================
# Server Configuration
# ===========================================
SERVICE_PORT=8080
APP_PORT=3000
NODE_ENV=development

# ===========================================
# Discord Webhook (for notifications)
# ===========================================
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/YOUR_WEBHOOK

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# Cache Configuration
# ===========================================
CACHE_TTL_MS=86400000
